<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.org.iopts.repository.DownloadMapper">

    <!--
        Actual remote DB schema:

        pi_download: download_id(PK auto_increment), download_file_id(int),
            user_no(varchar50), download_con(varchar2000),
            download_title(text), regdate(datetime)

        pi_download_file: (file attachment table for downloads)
            - Referenced via download_file_id FK in pi_download

        NOTE: Content column is download_con (varchar2000), NOT CONTENT.
              download_file_id is int FK, NOT a string.
    -->

    <!-- Download list with pagination -->
    <select id="selectDownloadList" parameterType="map"
            resultType="com.org.iopts.dto.response.DownloadResponse">
        SELECT
            d.download_id                                          AS downloadId,
            d.user_no                                              AS userNo,
            d.download_title                                       AS title,
            d.download_con                                         AS content,
            d.download_file_id                                     AS downloadFileId,
            DATE_FORMAT(d.regdate, '%Y-%m-%d %H:%i:%s')           AS regDt,
            u.USER_NAME                                            AS regUserName
        FROM pi_download d
        LEFT JOIN pi_user u ON d.user_no = u.USER_NO
        ORDER BY d.regdate DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!-- Count for pagination -->
    <select id="selectDownloadListCount" parameterType="map" resultType="long">
        SELECT COUNT(*)
        FROM pi_download
    </select>

    <!-- Download detail -->
    <select id="selectDownloadDetail" parameterType="long"
            resultType="com.org.iopts.dto.response.DownloadResponse">
        SELECT
            d.download_id                                          AS downloadId,
            d.user_no                                              AS userNo,
            d.download_title                                       AS title,
            d.download_con                                         AS content,
            d.download_file_id                                     AS downloadFileId,
            DATE_FORMAT(d.regdate, '%Y-%m-%d %H:%i:%s')           AS regDt,
            u.USER_NAME                                            AS regUserName
        FROM pi_download d
        LEFT JOIN pi_user u ON d.user_no = u.USER_NO
        WHERE d.download_id = #{downloadId}
    </select>

    <!-- Insert download record -->
    <insert id="insertDownload" parameterType="map" useGeneratedKeys="true" keyProperty="downloadId">
        INSERT INTO pi_download (
            user_no, download_title, download_con,
            download_file_id, regdate
        ) VALUES (
            #{userNo}, #{title}, #{content},
            #{downloadFileId}, NOW()
        )
    </insert>

    <!-- Delete download (physical delete) -->
    <delete id="deleteDownload" parameterType="long">
        DELETE FROM pi_download
        WHERE download_id = #{downloadId}
    </delete>

    <!-- updateDownloadCount - pi_download has no download count column; update notice_chk-style tracking not applicable here -->
    <update id="updateDownloadCount" parameterType="long">
        SELECT 1 FROM DUAL WHERE 1=0
    </update>

</mapper>
