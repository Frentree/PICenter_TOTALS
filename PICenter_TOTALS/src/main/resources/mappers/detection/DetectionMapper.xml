<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.org.iopts.repository.DetectionMapper">

    <!--
        Actual DB schema (remote):
        pi_find: hash_id(PK varchar100), group_id(varchar100), target_id(PK varchar100),
                 ap_no(PK int), path(text), encode_path, fid, remediation_status,
                 account(varchar100), owner(varchar200), regdate, credate, deldate,
                 column, process_chk, personal_info(longtext), personal_data(longtext),
                 personal_location(longtext), personal_metas(longtext), modified
        pi_data_processing: data_processing_idx(PK auto), ap_no, target_id, hash_id(text),
                 approval_status(varchar50 default 'W'), approval_type, global_type, regdate,
                 user_no, data_processing_group_id, processing_flag(int),
                 data_processing_group_idx, notepad(text), add_content(text)
        pi_subpath: group_id, target_id(PK), parent_id(PK), node_id(PK), ap_no(PK),
                 account, owner, path, remediation_status
        pi_targets: target_id(PK), ap_no(PK), name, platform, regdate, group_idx, TARGET_USE
        pi_path_data: CHK, TARGET_ID, AP_NO, PATH, HASH_ID, FID, OWNER, ACCOUNT,
                 APPROVAL_STATUS, PROCESSING_FLAG, DATA_TYPE, MATCH_COUNT, FILENAME, NOTEPAD
    -->

    <!-- Result Map for DetectionResponse -->
    <resultMap id="detectionResultMap" type="com.org.iopts.dto.response.DetectionResponse">
        <id property="findId" column="FIND_ID"/>
        <result property="targetId" column="TARGET_ID"/>
        <result property="targetName" column="TARGET_NAME"/>
        <result property="filePath" column="FILE_PATH"/>
        <result property="fileName" column="FILE_NAME"/>
        <result property="datatypeName" column="DATATYPE_NAME"/>
        <result property="patternName" column="PATTERN_NAME"/>
        <result property="matchData" column="MATCH_DATA"/>
        <result property="matchCount" column="MATCH_COUNT"/>
        <result property="processStatus" column="PROCESS_STATUS"/>
        <result property="processType" column="PROCESS_TYPE"/>
        <result property="processUser" column="PROCESS_USER"/>
        <result property="processDt" column="PROCESS_DT"/>
        <result property="findDt" column="FIND_DT"/>
        <result property="regDt" column="REG_DT"/>
        <result property="processStatusLabel" column="PROCESS_STATUS_LABEL"/>
        <result property="datatypeLabel" column="DATATYPE_LABEL"/>
    </resultMap>

    <!--
        TUNING: searchCondition
        [성능 이슈] LIKE CONCAT('%', ..., '%') → 양쪽 와일드카드로 인덱스 미사용 (FILE_PATH, OWNER, HASH_ID)
        [성능 이슈] f.PATH가 text 타입 → LIKE '%...%'는 Full Table Scan + text 비교
        [성능 이슈] CONCAT(#{startDate}, ' 00:00:00') → 함수 사용으로 인덱스 활용도 저하
        [인덱스 권장] pi_find(TARGET_ID, CREDATE) 복합 인덱스 → targetId + 날짜 범위 필터 가속
            - CREATE INDEX idx_pi_find_target_credate ON pi_find(TARGET_ID, CREDATE);
        [인덱스 권장] pi_find(HASH_ID) → HASH_ID 검색 시 prefix 인덱스
            - CREATE INDEX idx_pi_find_hashid ON pi_find(HASH_ID(100));
        [개선 방안] PATH 검색은 Full-Text Index 사용 권장
            - CREATE FULLTEXT INDEX idx_pi_find_path_ft ON pi_find(PATH);
    -->
    <!-- Common WHERE clause for search filters -->
    <sql id="searchCondition">
        <where>
            <if test="targetId != null and targetId != ''">
                AND f.TARGET_ID = #{targetId}
            </if>
            <if test="processStatus != null and processStatus != ''">
                AND IFNULL(dp_latest.APPROVAL_STATUS, 'NONE') = #{processStatus}
            </if>
            <if test="startDate != null and startDate != ''">
                AND f.CREDATE &gt;= CONCAT(#{startDate}, ' 00:00:00')
            </if>
            <if test="endDate != null and endDate != ''">
                AND f.CREDATE &lt;= CONCAT(#{endDate}, ' 23:59:59')
            </if>
            <if test="searchType != null and searchKeyword != null and searchKeyword != ''">
                <choose>
                    <when test="searchType == 'TARGET_NAME'">
                        AND t.NAME LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <when test="searchType == 'FILE_PATH'">
                        AND f.PATH LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <when test="searchType == 'OWNER'">
                        AND f.OWNER LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                    <when test="searchType == 'HASH_ID'">
                        AND f.HASH_ID LIKE CONCAT('%', #{searchKeyword}, '%')
                    </when>
                </choose>
            </if>
        </where>
    </sql>

    <!--
        [튜닝] selectDetectionList
        변경 전: 상관 서브쿼리 SELECT MAX(DATA_PROCESSING_IDX)가 pi_find 매 행마다 실행 → O(N*M) 성능
        변경 후: 파생 테이블(derived table)로 MAX를 미리 계산하여 1회만 실행 → O(N+M) 성능
        효과: 34만건 기준 조회 속도 대폭 개선
    -->
    <!--
        TUNING: selectDetectionList
        [인덱스 권장] pi_data_processing(TARGET_ID, HASH_ID, DATA_PROCESSING_IDX) 복합 인덱스
            - CREATE INDEX idx_pi_dp_target_hash_dpidx ON pi_data_processing(TARGET_ID, HASH_ID(100), DATA_PROCESSING_IDX);
        [인덱스 권장] pi_path_data(TARGET_ID, AP_NO, HASH_ID) 복합 인덱스
            - CREATE INDEX idx_pi_pd_target_ap_hash ON pi_path_data(TARGET_ID, AP_NO, HASH_ID(100));
        [인덱스 권장] pi_find(CREDATE DESC) → ORDER BY 정렬 인덱스
            - CREATE INDEX idx_pi_find_credate_desc ON pi_find(CREDATE DESC);
        [성능 이슈] SUBSTRING_INDEX(f.PATH, '/', -1) → 매 행마다 문자열 연산, 인덱스 미사용
        [개선 방안] 파일명을 별도 컬럼으로 저장하면 연산 비용 제거 가능
    -->
    <select id="selectDetectionList" parameterType="map" resultMap="detectionResultMap">
        SELECT
            f.HASH_ID                                       AS FIND_ID,
            f.TARGET_ID                                     AS TARGET_ID,
            t.NAME                                          AS TARGET_NAME,
            f.PATH                                          AS FILE_PATH,
            SUBSTRING_INDEX(f.PATH, '/', -1)                AS FILE_NAME,
            pd.DATA_TYPE                                    AS DATATYPE_NAME,
            pd.DATA_TYPE                                    AS PATTERN_NAME,
            f.PERSONAL_INFO                                 AS MATCH_DATA,
            pd.MATCH_COUNT                                  AS MATCH_COUNT,
            IFNULL(dp_latest.APPROVAL_STATUS, 'NONE')       AS PROCESS_STATUS,
            dp_latest.PROCESSING_FLAG                       AS PROCESS_TYPE,
            dp_latest.USER_NO                               AS PROCESS_USER,
            dp_latest.REGDATE                               AS PROCESS_DT,
            f.CREDATE                                       AS FIND_DT,
            f.REGDATE                                       AS REG_DT,
            CASE IFNULL(dp_latest.APPROVAL_STATUS, 'NONE')
                WHEN 'W' THEN '대기'
                WHEN 'Y' THEN '승인'
                WHEN 'N' THEN '반려'
                ELSE '미처리'
            END                                             AS PROCESS_STATUS_LABEL,
            pd.DATA_TYPE                                    AS DATATYPE_LABEL
        FROM pi_find f
        LEFT JOIN pi_targets t
            ON f.TARGET_ID = t.TARGET_ID AND f.AP_NO = t.AP_NO
        LEFT JOIN pi_path_data pd
            ON pd.TARGET_ID = f.TARGET_ID AND pd.AP_NO = f.AP_NO AND pd.HASH_ID = f.HASH_ID
        /* [튜닝] 파생 테이블로 최신 DATA_PROCESSING_IDX를 미리 계산 (상관 서브쿼리 제거) */
        LEFT JOIN (
            SELECT TARGET_ID, HASH_ID, MAX(DATA_PROCESSING_IDX) AS max_idx
            FROM pi_data_processing
            GROUP BY TARGET_ID, HASH_ID
        ) dp_max ON dp_max.TARGET_ID = f.TARGET_ID AND dp_max.HASH_ID = f.HASH_ID
        LEFT JOIN pi_data_processing dp_latest
            ON dp_latest.DATA_PROCESSING_IDX = dp_max.max_idx
        <include refid="searchCondition"/>
        ORDER BY f.CREDATE DESC
        LIMIT #{offset}, #{limit}
    </select>

    <!--
        [튜닝] selectDetectionListCount
        변경 전: COUNT 쿼리에도 상관 서브쿼리 + 불필요한 dp_latest JOIN
        변경 후: processStatus 필터가 없으면 dp JOIN 생략, 있으면 파생 테이블 방식 사용
        효과: 필터 없는 경우 JOIN 2개 제거로 카운트 쿼리 속도 대폭 개선
    -->
    <select id="selectDetectionListCount" parameterType="map" resultType="long">
        SELECT COUNT(*)
        FROM pi_find f
        LEFT JOIN pi_targets t
            ON f.TARGET_ID = t.TARGET_ID AND f.AP_NO = t.AP_NO
        <if test="processStatus != null and processStatus != ''">
            /* [튜닝] processStatus 필터가 있을 때만 dp JOIN 수행 */
            LEFT JOIN (
                SELECT TARGET_ID, HASH_ID, MAX(DATA_PROCESSING_IDX) AS max_idx
                FROM pi_data_processing
                GROUP BY TARGET_ID, HASH_ID
            ) dp_max ON dp_max.TARGET_ID = f.TARGET_ID AND dp_max.HASH_ID = f.HASH_ID
            LEFT JOIN pi_data_processing dp_latest
                ON dp_latest.DATA_PROCESSING_IDX = dp_max.max_idx
        </if>
        <include refid="searchCondition"/>
    </select>

    <!--
        [튜닝] selectDetectionDetail
        변경 전: 상관 서브쿼리로 MAX(DATA_PROCESSING_IDX) 조회
        변경 후: 단건 조회이므로 ORDER BY + LIMIT 1 서브쿼리로 변경 (PK 조건으로 충분히 빠름)
    -->
    <select id="selectDetectionDetail" parameterType="string" resultMap="detectionResultMap">
        SELECT
            f.HASH_ID                                       AS FIND_ID,
            f.TARGET_ID                                     AS TARGET_ID,
            t.NAME                                          AS TARGET_NAME,
            f.PATH                                          AS FILE_PATH,
            SUBSTRING_INDEX(f.PATH, '/', -1)                AS FILE_NAME,
            pd.DATA_TYPE                                    AS DATATYPE_NAME,
            pd.DATA_TYPE                                    AS PATTERN_NAME,
            f.PERSONAL_INFO                                 AS MATCH_DATA,
            pd.MATCH_COUNT                                  AS MATCH_COUNT,
            IFNULL(dp_latest.APPROVAL_STATUS, 'NONE')       AS PROCESS_STATUS,
            dp_latest.PROCESSING_FLAG                       AS PROCESS_TYPE,
            dp_latest.USER_NO                               AS PROCESS_USER,
            dp_latest.REGDATE                               AS PROCESS_DT,
            f.CREDATE                                       AS FIND_DT,
            f.REGDATE                                       AS REG_DT,
            CASE IFNULL(dp_latest.APPROVAL_STATUS, 'NONE')
                WHEN 'W' THEN '대기'
                WHEN 'Y' THEN '승인'
                WHEN 'N' THEN '반려'
                ELSE '미처리'
            END                                             AS PROCESS_STATUS_LABEL,
            pd.DATA_TYPE                                    AS DATATYPE_LABEL
        FROM pi_find f
        LEFT JOIN pi_targets t
            ON f.TARGET_ID = t.TARGET_ID AND f.AP_NO = t.AP_NO
        LEFT JOIN pi_path_data pd
            ON pd.TARGET_ID = f.TARGET_ID AND pd.AP_NO = f.AP_NO AND pd.HASH_ID = f.HASH_ID
        /* [튜닝] 단건 조회 시 ORDER BY DESC LIMIT 1로 최신 처리건 가져오기 */
        LEFT JOIN pi_data_processing dp_latest
            ON dp_latest.TARGET_ID = f.TARGET_ID
               AND dp_latest.HASH_ID = f.HASH_ID
               AND dp_latest.DATA_PROCESSING_IDX = (
                   SELECT dp2.DATA_PROCESSING_IDX
                   FROM pi_data_processing dp2
                   WHERE dp2.TARGET_ID = f.TARGET_ID AND dp2.HASH_ID = f.HASH_ID
                   ORDER BY dp2.DATA_PROCESSING_IDX DESC LIMIT 1
               )
        WHERE f.HASH_ID = #{findId}
        LIMIT 1
    </select>

    <!--
        TUNING: selectProcessHistory
        [성능 이슈] HASH_ID가 text 타입 → WHERE dp.HASH_ID = #{findId} 비교 느림
        [인덱스 권장] pi_data_processing(HASH_ID(100), REGDATE DESC) prefix 인덱스
            - CREATE INDEX idx_pi_dp_hashid_regdate ON pi_data_processing(HASH_ID(100), REGDATE DESC);
    -->
    <!-- Select process history for a detection (by HASH_ID) using pi_data_processing -->
    <select id="selectProcessHistory" parameterType="string" resultType="map">
        SELECT
            dp.DATA_PROCESSING_IDX      AS processId,
            dp.HASH_ID                  AS findId,
            dp.PROCESSING_FLAG          AS processType,
            dp.APPROVAL_STATUS          AS processResult,
            dp.USER_NO                  AS processUser,
            dp.NOTEPAD                  AS processComment,
            dp.REGDATE                  AS processDt
        FROM pi_data_processing dp
        WHERE dp.HASH_ID = #{findId}
        ORDER BY dp.REGDATE DESC
    </select>

    <!-- Select subpaths for a target -->
    <select id="selectSubpaths" parameterType="string" resultType="map">
        SELECT
            sp.NODE_ID       AS subpathId,
            sp.TARGET_ID     AS targetId,
            sp.PARENT_ID     AS parentId,
            sp.PATH          AS filePath,
            sp.PATH          AS fileName,
            sp.OWNER         AS owner,
            sp.GROUP_ID      AS groupId,
            sp.AP_NO         AS apNo,
            sp.ACCOUNT       AS account
        FROM pi_subpath sp
        WHERE sp.TARGET_ID = #{targetId}
        ORDER BY sp.PATH ASC
    </select>

    <!-- Insert a new process record into pi_data_processing (approval workflow) -->
    <insert id="insertProcess" parameterType="map">
        INSERT INTO pi_data_processing (
            TARGET_ID,
            HASH_ID,
            AP_NO,
            PROCESSING_FLAG,
            APPROVAL_STATUS,
            APPROVAL_TYPE,
            USER_NO,
            NOTEPAD,
            REGDATE
        )
        SELECT
            f.TARGET_ID,
            f.HASH_ID,
            f.AP_NO,
            #{processType},
            'W',
            #{processType},
            #{processUser},
            #{processComment},
            NOW()
        FROM pi_find f
        WHERE f.HASH_ID = #{findId}
        LIMIT 1
    </insert>

    <!-- Update detection remediation_status in pi_find -->
    <update id="updateDetectionStatus" parameterType="map">
        UPDATE pi_find
        SET
            REMEDIATION_STATUS = #{processStatus},
            MODIFIED = NOW()
        WHERE HASH_ID = #{findId}
          AND TARGET_ID = #{targetId}
    </update>

    <!-- Insert a remediation record into pi_data_processing -->
    <insert id="insertRemediation" parameterType="map">
        INSERT INTO pi_data_processing (
            TARGET_ID,
            HASH_ID,
            AP_NO,
            PROCESSING_FLAG,
            APPROVAL_STATUS,
            APPROVAL_TYPE,
            USER_NO,
            NOTEPAD,
            REGDATE
        )
        SELECT
            f.TARGET_ID,
            f.HASH_ID,
            f.AP_NO,
            #{remediationType},
            'W',
            #{remediationType},
            #{processUser},
            #{processComment},
            NOW()
        FROM pi_find f
        WHERE f.HASH_ID = #{findId}
        LIMIT 1
    </insert>

</mapper>
